{
  "manifest_version": 3,
  "name": "DownieClip — 视频下载助手",
  "version": "0.3.0",
  "description": "一键发送当前网页视频到 DownieClip 下载。支持 YouTube、Bilibili、Pornhub、hl718 等网站。",
  "author": "DownieClip",
  "homepage_url": "https://github.com/yangjiakang/claude-project",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "activeTab",
    "storage",
    "contextMenus"
  ],

  "host_permissions": [
    "http://localhost:8520/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "发送到 DownieClip",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "commands": {
    "send-to-downieclip": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      },
      "description": "发送当前页面到 DownieClip"
    }
  }
}
